<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>ToDo-Liste</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 600px;
            margin: 40px auto;
            padding: 0 20px;
        }
        h1 {
            color: #333;
        }
        #eingabeBereich {
            margin-bottom: 20px;
        }
        #todoEingabe {
            padding: 8px;
            width: 300px;
            font-size: 14px;
        }
        #hinzufuegenBtn {
            padding: 8px 16px;
            font-size: 14px;
            cursor: pointer;
        }
        ul {
            list-style: none;
            padding: 0;
        }
        li {
            padding: 8px;
            border-bottom: 1px solid #ddd;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        li.erledigt span {
            text-decoration: line-through;
            color: #999;
        }
        .loeschenLink {
            color: red;
            cursor: pointer;
            margin-left: auto;
        }
        .loeschenLink:hover {
            text-decoration: underline;
        }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
</head>
<body>
    <h1>Meine ToDo-Liste</h1>

    <div id="eingabeBereich">
        <input type="text" id="todoEingabe" placeholder="Neues ToDo eingeben...">
        <button id="hinzufuegenBtn">Hinzufuegen</button>
    </div>

    <ul id="todoListe"></ul>

    <script>
    $(document).ready(function () {

        // Gespeicherte ToDos aus localStorage laden (Bonus-Aufgabe c)
        function todosLaden() {
            var gespeichert = localStorage.getItem("todos");
            if (gespeichert) {
                var todos = JSON.parse(gespeichert);
                for (var i = 0; i < todos.length; i++) {
                    todoHinzufuegen(todos[i].text, todos[i].erledigt);
                }
              }
        }

        // Alle ToDos in localStorage speichern
        function todosSpeichern() {
            var todos = [];
            $("#todoListe li").each(function () {
                todos.push({
                    text: $(this).find("span").text(),
                    erledigt: $(this).hasClass("erledigt")
                    });
            });
            localStorage.setItem("todos", JSON.stringify(todos));
        }

        // Neues ToDo-Element erstellen und an die Liste anhaengen
        function todoHinzufuegen(text, erledigt) {
            var li = $("<li>");
            var checkbox = $("<input>").attr("type", "checkbox");
            var textSpan = $("<span>").text(text);
            var loeschLink = $("<a>").addClass("loeschenLink").text("Entfernen");

            if (erledigt) {
                checkbox.prop("checked", true);
                li.addClass("erledigt");
            }

            // Event: Checkbox zum Markieren als erledigt
            checkbox.on("change", function () {
                if ($(this).is(":checked")) {
                    li.addClass("erledigt");
                } else {
                    li.removeClass("erledigt");
                }
                todosSpeichern();
            });

            // Event: Klick auf Entfernen-Link
            loeschLink.on("click", function () {
                li.remove();
                todosSpeichern();
            });

            li.append(checkbox).append(textSpan).append(loeschLink);
            $("#todoListe").append(li);
        }

        // Event: Klick auf Hinzufuegen-Button

        $("#hinzufuegenBtn").on("click", function () {
            var text = $("#todoEingabe").val().trim();
            if (text.length > 0) {
                todoHinzufuegen(text, false);
                $("#todoEingabe").val("");
                todosSpeichern();
            }
        });

        // Event: Enter-Taste im Eingabefeld

        $("#todoEingabe").on("keypress", function (e) {
            if (e.which === 13) {
                $("#hinzufuegenBtn").trigger("click");
            }
        });

        // Beim Laden der Seite gespeicherte ToDos wiederherstellen
        todosLaden();
    });
    </script>
</body>
</html>
